{
  "name": "itecify-vscode",
  "displayName": "iTECify",
  "description": "Execute code in iTECify cloud environment",
  "version": "0.1.0",
  "publisher": "itecify",
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "itecify.runCloudExecution",
        "title": "iTECify: Run Code in Cloud",
        "icon": "$(play)"
      },
      {
        "command": "itecify.pullCode",
        "title": "iTECify: Pull Code from Cloud",
        "icon": "$(cloud-download)"
      },
      {
        "command": "itecify.pushCode",
        "title": "iTECify: Push Code to Cloud",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "itecify.connectWorkspace",
        "title": "iTECify: Connect Workspace",
        "icon": "$(plug)"
      },
      {
        "command": "itecify.createBranch",
        "title": "iTECify: New Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "itecify.deleteBranch",
        "title": "iTECify: Delete Branch",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "itecify.runCloudExecution",
          "group": "navigation",
          "when": "resourceLangId == python || resourceLangId == javascript || resourceLangId == javascriptreact"
        },
        {
          "command": "itecify.pushCode",
          "group": "navigation@1",
          "when": "resourceScheme == file"
        },
        {
          "command": "itecify.pullCode",
          "group": "navigation@2",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "iTECify",
      "properties": {
        "itecify.backendBaseUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL for the iTECify FastAPI backend."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "install-local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-local.ps1"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  }
}
